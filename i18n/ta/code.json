  "homepage.sponsors.tier.silver": {
    "message": "வெள்ளி ஆதரவாளர்"
  },
  "homepage.sponsors.title": {
    "message": "ஸ்பான்சர்"
  },
  "homepage.translations.button": {
    "message": "Crowdin இல் மொழிபெயர்ப்பில் பங்கேற்கவும்"
  },
  "homepage.translations.subtitle": {
    "message": "தயவு செய்து மொழிபெயர்ப்புகளுக்கு பங்களிக்கவும், இதனால் உலகெங்கிலும் உள்ள டெவலப்பர்கள் மொழி தடைகள் இல்லாமல் Wave ஐக் கற்றுக்கொள்ள முடியும்."
  },
