  "homepage.features.one.description": {
    "message": "Wave reduziert unnötigen Code und ermöglicht es Ihnen, sich auf die Kernlogik zu konzentrieren. Dank der modernen Syntax ist es leicht zu erlernen und macht Spaß."
  },
  "homepage.features.one.title": {
    "message": "prägnant und intuitiv"
  },
  "homepage.features.three.description": {
    "message": "Verhindert häufige Fehler wie Nullreferenzfehler zur Kompilierungszeit. Das integrierte Parallelitätsmodell macht die Multicore-Programmierung einfacher als je zuvor."
  },
  "homepage.features.three.title": {
    "message": "sicher und gleichzeitig"
  },
  "homepage.features.two.description": {
    "message": "Durch die Kompilierung in nativen Code erreicht es durch Null-Kosten-Abstraktion eine Leistung auf C++-Niveau. Ideal für ressourcenkritische Aufgaben."
  },
  "homepage.features.two.title": {
    "message": "schnell und effizient"
  },
  "homepage.hero.subtitle": {
    "message": "Intuitive Syntax, leistungsstarke Leistung und integrierte Sicherheit. Wave wurde entwickelt, um Ihre Produktivität zu steigern und Ihre Anwendungen robust zu machen."
  },
  "homepage.hero.title": {
    "message": "Eine moderne Sprache für eine neue Entwicklungswelle"
  },
