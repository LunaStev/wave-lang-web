  "homepage.translations.button": {
    "message": "Crowdinలో అనువాదంలో పాల్గొనండి"
  },
  "homepage.translations.subtitle": {
    "message": "దయచేసి అనువాదాలకు సహకరించండి, తద్వారా ప్రపంచవ్యాప్తంగా ఉన్న డెవలపర్‌లు భాషా అవరోధాలు లేకుండా Waveని నేర్చుకోగలరు."
  },
