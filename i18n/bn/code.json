  "homepage.contributors.title": {
    "message": "অবদানকারী"
  },
  "homepage.features.one.description": {
    "message": "Wave অপ্রয়োজনীয় কোড হ্রাস করে এবং আপনাকে মূল যুক্তিতে ফোকাস করতে দেয়। আধুনিক সিনট্যাক্স শিখতে সহজ এবং ব্যবহার করা মজাদার করে তোলে।"
  },
  "homepage.features.one.title": {
    "message": "সংক্ষিপ্ত এবং স্বজ্ঞাত"
  },
  "homepage.features.three.description": {
    "message": "কম্পাইল সময়ে নাল রেফারেন্স ত্রুটির মত সাধারণ বাগ প্রতিরোধ করে। বিল্ট-ইন কনকারেন্সি মডেল মাল্টিকোর প্রোগ্রামিংকে আগের চেয়ে সহজ করে তোলে।"
  },
  "homepage.features.three.title": {
    "message": "নিরাপদ এবং একযোগে"
  },
  "homepage.features.two.description": {
    "message": "নেটিভ কোডে সংকলিত, এটি শূন্য-খরচ বিমূর্ততার মাধ্যমে C++ স্তরের কর্মক্ষমতা অর্জন করে। সম্পদ-সমালোচনামূলক কাজের জন্য আদর্শ।"
  },
  "homepage.features.two.title": {
    "message": "দ্রুত এবং দক্ষ"
  },
  "homepage.hero.subtitle": {
    "message": "স্বজ্ঞাত সিনট্যাক্স, শক্তিশালী কর্মক্ষমতা, এবং অন্তর্নির্মিত নিরাপত্তা। Wave আপনার উত্পাদনশীলতা বাড়াতে এবং আপনার অ্যাপ্লিকেশনগুলিকে শক্তিশালী করার জন্য ডিজাইন করা হয়েছে৷"
  },
  "homepage.hero.title": {
    "message": "উন্নয়নের একটি নতুন তরঙ্গের জন্য একটি আধুনিক ভাষা"
  },
