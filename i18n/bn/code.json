  },
  "homepage.translations.subtitle": {
    "message": "অনুগ্রহ করে অনুবাদগুলিতে অবদান রাখুন যাতে সারা বিশ্বের বিকাশকারীরা ভাষা বাধা ছাড়াই Wave শিখতে পারে৷"
